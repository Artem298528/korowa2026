// ======================= РЕАЛИЗАЦИИ =======================
void initVL53() {
  pinMode(XSHUT_LEFT, OUTPUT);
  pinMode(XSHUT_RIGHT, OUTPUT);
  digitalWrite(XSHUT_LEFT, LOW);
  digitalWrite(XSHUT_RIGHT, LOW);
  delay(50);
  Wire.begin(SDA_PIN, SCL_PIN);
  delay(10);
  digitalWrite(XSHUT_LEFT, HIGH);
  delay(50);
  sensorLeft.setTimeout(100);
  if (sensorLeft.init()) {
    sensorLeft.setAddress(VL53_ADDR_LEFT);
    sensorLeft.setMeasurementTimingBudget(30000);
    sensorLeft.startContinuous();
    vl53LeftOk = true;
    Serial.println("VL53 LEFT init OK, addr=0x30");
  } else {
    vl53LeftOk = false;
    Serial.println("VL53 LEFT init FAIL");
  }
  digitalWrite(XSHUT_RIGHT, HIGH);
  delay(50);
  sensorRight.setTimeout(100);
  if (sensorRight.init()) {
    sensorRight.setMeasurementTimingBudget(30000);
    sensorRight.startContinuous();
    vl53RightOk = true;
    Serial.println("VL53 RIGHT init OK, addr=0x29");
  } else {
    vl53RightOk = false;
    Serial.println("VL53 RIGHT init FAIL");
  }
}

void updateVL53() {
  unsigned long now = millis();
  if (now - lastVL53Update < VL53_INTERVAL_MS) return;
  lastVL53Update = now;
  vl53NewData = false;
  if (vl53LeftOk) {
    uint16_t value = sensorLeft.readRangeContinuousMillimeters();
    if (!sensorLeft.timeoutOccurred()) distLeft = value;
  }
  if (vl53RightOk) {
    uint16_t value = sensorRight.readRangeContinuousMillimeters();
    if (!sensorRight.timeoutOccurred()) distRight = value;
  }
  vl53NewData = true;
}

bool isObstacleDetected() {
  if (vl53ManuallyDisabled) return false;
  bool leftBlocked  = (vl53LeftOk  && distLeft  > 0 && distLeft  < OBSTACLE_LIMIT_MM);
  bool rightBlocked = (vl53RightOk && distRight > 0 && distRight < OBSTACLE_LIMIT_MM);
  return leftBlocked || rightBlocked;
}

void printDistances() {
  Serial.print("VL53 LEFT: ");
  if (vl53LeftOk) Serial.print(distLeft); else Serial.print("ERR");
  Serial.print(" mm | RIGHT: ");
  if (vl53RightOk) Serial.print(distRight); else Serial.print("ERR");
  Serial.println(" mm");
}

void setupSteppers() {
  stepper1.setRunMode(FOLLOW_POS);
  stepper2.setRunMode(FOLLOW_POS);
  stepper1.setMaxSpeed(500);
  stepper1.setAcceleration(500);
  stepper2.setMaxSpeed(500);
  stepper2.setAcceleration(500);
  stepper1.autoPower(true);
  stepper2.autoPower(true);
  stepper1.reverse(false);
  stepper2.reverse(true);
  stepper1.disable();
  stepper2.disable();
  steppersEnabled = false;
  Serial.println("STEPPERS CONFIGURED, DISABLED");
}

void enableSteppersIfNeeded() {
  if (!steppersEnabled) {
    stepper1.enable();
    stepper2.enable();
    steppersEnabled = true;
    Serial.println("STEPPERS ENABLED");
  }
}

void disableSteppers() {
  stepper1.disable();
  stepper2.disable();
  steppersEnabled = false;
  Serial.println("STEPPERS DISABLED");
}

bool isServoAvailable(int index) {
  return (index >= 0 && index < SERVO_COUNT && SERVO_PINS[index] != SERVO_UNUSED);
}

void attachAndWriteServo(int index, int angle) {
  if (!isServoAvailable(index)) return;
  angle = constrain(angle, 0, 180);
  servos[index].attach(SERVO_PINS[index], SERVO_MIN_US, SERVO_MAX_US);
  servos[index].write(angle);
  Serial.printf("SERVO %d (GPIO%d) -> %d°\n", index, SERVO_PINS[index], angle);
}

void attachAndWriteTwoServos(int idx1, int ang1, int idx2, int ang2) {
  attachAndWriteServo(idx1, ang1);
  attachAndWriteServo(idx2, ang2);
}

void detachAllServos() {
  // Функция оставлена, но нигде не вызывается – сервы всегда под напряжением.
  // for (int i = 0; i < SERVO_COUNT; i++) {
  //   if (isServoAvailable(i)) servos[i].detach();
  // }
  Serial.println("detachAllServos() called but detach is disabled");
}

void finalServoLoop() {
  const int actuatorIdx = 0;
  if (!isServoAvailable(actuatorIdx)) {
    delay(1000);
    return;
  }
  servos[actuatorIdx].attach(SERVO_PINS[actuatorIdx], SERVO_MIN_US, SERVO_MAX_US);
  while (true) {
    for (int angle = 0; angle <= 180; angle++) {
      servos[actuatorIdx].write(angle);
      delay(15);
    }
    for (int angle = 180; angle >= 0; angle--) {
      servos[actuatorIdx].write(angle);
      delay(15);
    }
  }
}

void startRouteStep(RouteStep step) {
  stepStartTime = millis();
  if (step.type == MOVE_STEPPERS) {
    motorsWereMoving = false;
    Serial.printf("MOVE: %ld / %ld steps\n", step.motor1Steps, step.motor2Steps);
    enableSteppersIfNeeded();
    stepper1.setTarget(step.motor1Steps, RELATIVE);
    stepper2.setTarget(step.motor2Steps, RELATIVE);
  }
  else if (step.type == SERVO_MOVE) {
    Serial.println("SERVO_MOVE");
    attachAndWriteServo(step.servoIndex1, step.servoAngle1);
  }
  else if (step.type == SERVO_MOVE_2) {
    Serial.println("SERVO_MOVE_2");
    attachAndWriteTwoServos(step.servoIndex1, step.servoAngle1,
                            step.servoIndex2, step.servoAngle2);
  }
  else if (step.type == PAUSE_STEP) {
    Serial.printf("PAUSE: %lu ms\n", step.timeMs);
  }
  stepStarted = true;
}

bool isRouteStepFinished(RouteStep step, byte stepper1Move, byte stepper2Move) {
  if (step.type == MOVE_STEPPERS) {
    if (stepper1Move != 0 || stepper2Move != 0) motorsWereMoving = true;
    return motorsWereMoving && stepper1Move == 0 && stepper2Move == 0;
  }
  if (step.type == SERVO_MOVE || step.type == SERVO_MOVE_2) {
    if (millis() - stepStartTime >= step.timeMs) {
      // detachAllServos();   // отключено – сервы остаются под напряжением
      return true;
    }
    return false;
  }
  if (step.type == PAUSE_STEP) {
    return (millis() - stepStartTime >= step.timeMs);
  }
  return false;
}

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n========================================");
  Serial.println("ROBOT START – STEPPERS ENABLE ONLY ON MOVE");
  Serial.println("SERVOS ALWAYS POWERED (NO DETACH)");
  Serial.println("========================================");

  pinMode(STARTER_PIN, INPUT_PULLUP);
  pinMode(SIDE_PIN, INPUT_PULLUP);

  setupSteppers();
  initVL53();

  Serial.println("Servo configuration:");
  for (int i = 0; i < SERVO_COUNT; i++) {
    Serial.printf("Servo %d: ", i);
    if (SERVO_PINS[i] == SERVO_UNUSED) Serial.println("UNUSED");
    else Serial.printf("GPIO%d\n", SERVO_PINS[i]);
  }

  if (digitalRead(SIDE_PIN) == LOW) {
    currentRoute = route2;
    Serial.println("Selected route: 2 (blue)");
  } else {
    currentRoute = route1;
    Serial.println("Selected route: 1 (orange)");
  }

  Serial.println("Waiting STARTER press...");
  while (digitalRead(STARTER_PIN) == HIGH) {
    updateVL53();
    if (vl53NewData) {
      vl53NewData = false;
      printDistances();
    }
    delay(20);
  }
  delay(100);
  robotStartTime = millis();
  Serial.println("START!");
}

void loop() {
  updateVL53();
  if (vl53NewData) {
    vl53NewData = false;
    printDistances();
  }

  if (!routeFinished && !timeoutFinished) {
    if (millis() - robotStartTime >= MAX_RUN_TIME_MS) {
      timeoutFinished = true;
      routeFinished = true;
      disableSteppers();
      // detachAllServos();
      Serial.println("TIMEOUT 98 SEC. ROUTE STOPPED.");
    }
  }

  if (routeFinished) {
    finalServoLoop();
    return;
  }

  RouteStep currentStep = currentRoute[currentStepIndex];

  if (currentStep.type == END_ROUTE) {
    routeFinished = true;
    disableSteppers();
    // detachAllServos();
    Serial.println("ROUTE FINISHED. FINAL SERVO LOOP STARTED.");
    return;
  }

  bool blocked = currentStep.useDistanceSafety && isObstacleDetected();
  static bool wasBlocked = false;
  if (blocked) {
    if (!wasBlocked) {
      Serial.println("OBSTACLE! Waiting...");
      printDistances();
      wasBlocked = true;
    }
    delay(5);
    return;
  }
  if (wasBlocked) {
    Serial.println("Obstacle cleared. Continue.");
    printDistances();
    wasBlocked = false;
  }

  byte stepper1Move = stepper1.tick();
  byte stepper2Move = stepper2.tick();

  if (!stepStarted) {
    startRouteStep(currentStep);
  }

  if (isRouteStepFinished(currentStep, stepper1Move, stepper2Move)) {
    Serial.printf("Step %d finished.\n", currentStepIndex);
    currentStepIndex++;
    stepStarted = false;
    motorsWereMoving = false;
    delay(50);
  }
}
